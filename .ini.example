; LIMEVIDEO PLATFORM CONFIGURATION (EXAMPLE)

; Application
DEV_MODE=false

; Site Settings
SITE_DOMAIN=127.0.0.1:8010
SITE_HTTPS=false

; Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=limevideo
DB_USER=root
DB_PASSWORD=your_password
DB_CHARSET=utf8mb4

; Storage
STORAGE_VIDEO_PATH=./uploads/videos
STORAGE_THUMB_PATH=./uploads/thumbs
STORAGE_MAX_SIZE=104857600

; Chat
CHAT_VIDEO_ID=globalchat01
CHAT_OWNER_USER_ID=u_system
CHAT_MESSAGE_LIMIT=50
CHAT_MESSAGE_MAX_LENGTH=500

; Cron & Analytics
CRON_TOKEN=
CRON_AUTO_RUN_ENABLED=false
CRON_AUTO_RUN_LIMIT=2
CRON_AUTO_RUN_MIN_INTERVAL=60
ANALYTICS_ROLLUP_ENABLED=true
ANALYTICS_ROLLUP_LOOKBACK_HOURS=48
ANALYTICS_ROLLUP_LOOKBACK_DAYS=14
ANALYTICS_RAW_RETENTION_DAYS=90
ANALYTICS_AUTO_ENQUEUE_MIN_INTERVAL=300

; Security & Providers
VIDEO_PROVIDER_MANUAL_EXTERNAL_WEBHOOK_SECRET=change-me
